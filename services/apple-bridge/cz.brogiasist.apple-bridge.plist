<plist version="1.0">
<dict>
    <key>Label</key>
    <string>cz.brogiasist.apple-bridge</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/pavel/SynologyDrive/001 DXP/009 BrogiASIST/services/apple-bridge/run.sh</string>
    </array>
